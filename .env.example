# Supabase (obrigatório)
SUPABASE_URL=https://<project>.supabase.co

# SUPABASE_KEY — papel depende do contexto:
#   Streamlit / Railway (server-side): use a SERVICE_ROLE key → bypassa RLS, dados sempre acessíveis
#   PWA browser (web/): use a ANON key → sujeita a RLS, requer sessão autenticada
#
# Antes da Fase 0 (RLS não ativo): anon key funciona em ambos
# Após a Fase 0 (005b aplicado):   Streamlit Cloud DEVE usar service_role key
SUPABASE_KEY=<service_role_key_para_streamlit>         # Settings → API → service_role

# Para o script de verificação RLS (scripts/verify_rls.py) — não vai para produção:
SUPABASE_ANON_KEY=<anon_key>                           # Settings → API → anon/public
SUPABASE_SERVICE_KEY=<service_role_key>

# Provedores de IA (M4 — AI Consilium)
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
OPENAI_API_KEY=sk-...
DASHSCOPE_API_KEY=sk-...
MOONSHOT_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...

# Redis (opcional — sem ela usa fakeredis in-memory)
REDIS_URL=redis://localhost:6379

# Telegram Bot (Fase 6)
# 1. Crie o bot: converse com @BotFather no Telegram → /newbot
# 2. Copie o token gerado
TELEGRAM_BOT_TOKEN=123456789:AAF...
# 3. Descubra seu ID numérico: converse com @userinfobot → copie "Id:"
TELEGRAM_ALLOWED_USER_IDS=123456789
